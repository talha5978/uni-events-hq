{
	"extends": "../../tsconfig.json",
	"references": [{ "path": "../../packages/db" }],
	"include": ["src"],
	"exclude": ["dist", "node_modules", "build"],
	"compilerOptions": {
		"rootDir": "src",
		"outDir": "dist",
		"declaration": true,
		"declarationMap": true,
		"strict": true,
		"target": "ES2022",
		"module": "ES2022",
		"moduleResolution": "bundler",
		"types": ["node"],
		"paths": {
			"~/*": ["./src/*"]
		}
	}
}
